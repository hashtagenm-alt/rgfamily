# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# claude
.claude/cache/
.claude/hooks/node_modules/
.claude/settings.local.json

# python
__pycache__/
*.py[cod]
*$py.class
.Python
*.so

# sensitive data (accounts, passwords)
/data/*.csv
/data/*.xlsx
vip-accounts.csv

# Bulk upload generated CSVs
scripts/bulk-upload-signature-videos/*.csv

# Large binary directories (videos, downloads, thumbnails)
scripts/downloads/
scripts/downloaded-videos/
scripts/thumbnails/
scripts/data/
download-log.txt

# DB backups
backups/
/data/db-export-*/

# Video downloads (incomplete/temp)
시즌1/

# Vercel local tokens
.env.vercel.local
_docs/
_shared/
/media/
scripts/migrate/cf-vimeo-mapping.json
